{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "(LibViso2 App) Clean",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "if (Test-Path build) { Remove-Item -Recurse -Force build }; New-Item -ItemType Directory -Path build"
            ],
            "problemMatcher": []
        },
        {
            "label": "(LibViso2 App) Configure",
            "type": "process",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\scripts\\cmake-configure.ps1",
                "-SourceDir",
                "../",
                "-Platform",
                "${config:libviso2.targetPlatform}"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": [
                "(Dependencies) Build"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "isBackground": false
        },
        {
            "label": "(LibViso2 App) Build [Debug]",
            "type": "process",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\scripts\\cmake-build.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": [
                "(LibViso2 App) Configure"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "isBackground": false
        },
        {
            "label": "(LibViso2 App) Build [Release]",
            "type": "process",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\scripts\\cmake-build.ps1",
                ".",
                "Release"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": [
                "(LibViso2 App) Configure"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "isBackground": false
        },
        {
            "label": "(LibViso2 App) Clean and Rebuild [Debug]",
            "dependsOn": [
                "(LibViso2 App) Clean",
                "(LibViso2 App) Build [Debug]"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "(LibViso2 App) Clean and Rebuild [Release]",
            "dependsOn": [
                "(LibViso2 App) Clean",
                "(LibViso2 App) Build [Release]"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "(Dependencies) Build",
            "type": "process",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\scripts\\build-dependencies.ps1",
                "-Platform",
                "${config:libviso2.targetPlatform}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "isBackground": false
        },
        {
            "label": "(Dependencies) Rebuild",
            "type": "process",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\scripts\\build-dependencies.ps1",
                "-Platform",
                "${config:libviso2.targetPlatform}",
                "-Force"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "isBackground": false
        }
    ]
}
