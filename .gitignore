# Build output (root app + libviso2 lib, wherever they live)
build/
/out/
cmake-build-*/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
Makefile
*.cmake
!CMakeLists.txt
_deps/

# Compiled object / intermediate files
*.slo
*.lo
*.o
*.obj
*.exp
*.ilk
*.pdb

# MSVC / MSBuild intermediate & log artifacts (never commit these)
*.tlog
*.sbr
*.bsc
*.res
*.lastbuildstate
*.recipe
*.idb

# Precompiled headers
*.gch
*.pch

# Executables
*.exe
*.out
*.app

# ============================================================
# Prebuilt dependencies (zlib / libpng / libviso2), per target platform.
#  - Win32 binaries are COMMITTED: the default, zero-friction build baseline
#    (especially for libpng/zlib whose sources we don't redistribute).
#  - Other targets (x64 / ARM64) are generated on-demand by the
#    "Dependencies Build" task -> git-ignored.
# ============================================================
libs/bin/*/
libs/lib/*/
!libs/bin/Win32/
!libs/lib/Win32/

# IDE - Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sdf
*.opensdf
*.vcxproj.filters
*.vcproj.filters
ipch/

# IDE - VS Code (keep the shared project config)
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/scripts/
*.code-workspace

# IDE - JetBrains (CLion)
.idea/
*.iws
*.iml
*.ipr

# System files
.DS_Store
Thumbs.db
Desktop.ini

# Logs and databases
*.log
*.sql
*.sqlite

# Project specifics
# Datasets are large and downloaded separately (see README) -> keep them out of git.
# Everything else under assets/ (e.g. screenshots referenced by the README) stays tracked.
assets/datasets/

# Temp files
temp/